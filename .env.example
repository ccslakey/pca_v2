# Copy to .env for local overrides (never commit .env)

# Django core
DJANGO_SECRET_KEY=change-me-use-django-get-random-secret-key
DJANGO_DEBUG=False
# Comma-separated; add your Railway domain once you have it
DJANGO_ALLOWED_HOSTS=your-app.railway.app

# Database — Railway Postgres plugin sets this automatically
DATABASE_URL=postgres://user:password@host:5432/dbname

# CSRF — must match your public URL(s)
CSRF_TRUSTED_ORIGINS=https://your-app.railway.app

# Optional tuning
WEB_CONCURRENCY=2
