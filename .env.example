# Copy to .env (gitignored) and fill in. Loaded automatically by settings.py in dev.
# All are optional — without them the AI features degrade gracefully (template
# narrative, empty methodology search).

# Anthropic — enables LLM-generated career narratives.
ANTHROPIC_API_KEY=

# Voyage — enables methodology embeddings + semantic search.
# After setting, run: python manage.py index_methodology
VOYAGE_API_KEY=

# Optional overrides (defaults shown):
# NARRATIVE_MODEL=claude-haiku-4-5-20251001
# NARRATIVE_USE_TOOLS=true   # false = single-shot instead of the tool-calling agent
# EMBED_MODEL=voyage-3.5-lite
